# =============================================================================
# IronKey UI — Variables de entorno
# Copia este archivo como .env.local para desarrollo local
# En producción Vite usa .env.production automáticamente al hacer npm run build
# NUNCA subas .env.local al repositorio (ya está en .gitignore via *.local)
# =============================================================================

# URL base del backend (sin trailing slash opcional, el HttpService lo normaliza)
# Desarrollo: http://localhost:8080/
# Producción: https://testironkey.contragamer.com/
VITE_API_BASE_URL=http://localhost:8080/
